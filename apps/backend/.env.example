APP_NAME=OpsDeck Control Tower API
APP_ENV=development
APP_DEBUG=false
API_V1_PREFIX=/api/v1
DEFAULT_TENANT_SLUG=demo-steel
DATABASE_URL=postgresql+psycopg://steelops:steelops@postgres:5432/steelops
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
SECRET_KEY=replace-with-a-long-random-production-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=["https://opsdeck.in","https://app.opsdeck.in"]
MAX_REQUEST_BODY_BYTES=31457280
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/microsoft/callback
ENCRYPTION_KEY=replace-me-with-a-fernet-key
